{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gloamy",
  "version": "0.1.8",
  "identifier": "com.gloamy.desktop",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Gloamy",
        "label": "main",
        "width": 1000,
        "height": 800,
        "center": true,
        "focus": true,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": ".*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Gloamy desktop runtime and control center.",
    "longDescription": "Gloamy is a Rust-first autonomous agent runtime desktop app focused on performance, stability, and secure operations.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
